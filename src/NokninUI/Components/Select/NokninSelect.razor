<div class="@RootClass" style="@Style" @ref="_rootElement">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="noknin-select__label" id="@LabelId">
            @Label

            @if (Required)
            {
                <span class="noknin-select__required" aria-hidden="true">*</span>
            }
        </label>
    }

    <button id="@TriggerId" type="button" class="noknin-select__trigger" role="combobox" aria-haspopup="listbox"
            aria-expanded="@IsOpen.ToString().ToLowerInvariant()" aria-controls="@ListboxId"
            aria-labelledby="@AriaLabelledBy" aria-describedby="@DescribedBy" aria-activedescendant="@ActiveDescendantId"
            aria-required="@Required.ToString().ToLowerInvariant()" aria-invalid="@HasError.ToString().ToLowerInvariant()"
            aria-disabled="@Disabled.ToString().ToLowerInvariant()" disabled="@Disabled" @onclick="ToggleAsync"
            @onkeydown="HandleKeyDownAsync">
        <span class="@ValueClass">
            @SelectedLabel
        </span>

        <span class="noknin-select__chevron" aria-hidden="true">
            ▾
        </span>
    </button>

    @if (IsOpen)
    {
        <ul id="@ListboxId" class="noknin-select__listbox" role="listbox" aria-labelledby="@LabelId">
            @for (var index = 0; index < Options.Count; index++)
            {
                var optionIndex = index;
                var option = Options[optionIndex];
                var isSelected = IsSelected(option);
                var isActive = optionIndex == _activeIndex;

                <li id="@GetOptionId(optionIndex)" class="@GetOptionClass(option, optionIndex)" role="option"
                    aria-selected="@isSelected.ToString().ToLowerInvariant()"
                    aria-disabled="@option.Disabled.ToString().ToLowerInvariant()"
                    @onclick="() => SelectOptionAsync(optionIndex)">
                    @option.Label
                </li>
            }
        </ul>
    }

    @if (!string.IsNullOrWhiteSpace(Description) && !HasError)
    {
        <div id="@DescriptionId" class="noknin-select__description">
            @Description
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(ErrorText))
    {
        <div id="@ErrorId" class="noknin-select__error">
            @ErrorText
        </div>
    }
</div>
