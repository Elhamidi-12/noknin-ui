<div class="@ClassNames"
     role="@ComputedRole"
     aria-live="@ComputedAriaLive">
    @if (ShowIcon)
    {
        <span class="noknin-alert__icon" aria-hidden="true">
            <NokninIcon Name="@IconName" Size="NokninSize.Small" />
        </span>
    }

    <div class="noknin-alert__body">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <div class="noknin-alert__title">
                @Title
            </div>
        }

        @if (ChildContent is not null)
        {
            <div class="noknin-alert__content">
                @ChildContent
            </div>
        }
    </div>

    @if (Dismissible)
    {
        <button class="noknin-alert__dismiss"
                type="button"
                aria-label="Dismiss alert"
                @onclick="OnDismiss">
            <NokninIcon Name="NokninIconName.X" />
        </button>
    }
</div>
