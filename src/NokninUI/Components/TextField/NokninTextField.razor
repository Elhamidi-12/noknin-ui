<div class="@WrapperClassNames" style="@Style">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="noknin-textfield__label" for="@InputId">
            @Label
            @if (Required)
            {
                <span class="noknin-textfield__required" aria-hidden="true">*</span>
            }
        </label>
    }

    <input id="@InputId"
           class="noknin-textfield__input"
           value="@Value"
           placeholder="@Placeholder"
           disabled="@Disabled"
           required="@Required"
           aria-invalid="@HasError"
           aria-describedby="@DescribedBy"
           @oninput="HandleInput" />

    @if (!string.IsNullOrWhiteSpace(Description) && !HasError)
    {
        <p id="@DescriptionId" class="noknin-textfield__description">
            @Description
        </p>
    }

    @if (HasError)
    {
        <p id="@ErrorId" class="noknin-textfield__error">
            @ErrorText
        </p>
    }
</div>
