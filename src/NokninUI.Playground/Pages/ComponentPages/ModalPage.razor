@page "/components/modal"
@using NokninUI.Data.Enums

<PageTitle>Modal - NokninUI</PageTitle>

<div class="demo-page">
    <div class="demo-header">
        <p class="demo-eyebrow">Component</p>
        <h1>Modal</h1>
        <p>Use modals for focused tasks that require the user to make a decision or complete an action.</p>
    </div>

    <h2>Example</h2>

    <NokninButton Variant="NokninVariant.Primary" OnClick="OpenModal">
        Open modal
    </NokninButton>

    <NokninModal Open="@_modalOpen"
                 OpenChanged="@(value => _modalOpen = value)"
                 Title="Delete project"
                 Size="NokninModalSize.Medium">

        <ChildContent>
            Are you sure you want to delete this project? This action cannot be undone.
        </ChildContent>

        <Footer>
            <NokninButton Variant="NokninVariant.Ghost" OnClick="CloseModal">
                Cancel
            </NokninButton>

            <NokninButton Variant="NokninVariant.Destructive" OnClick="CloseModal">
                Delete
            </NokninButton>
        </Footer>
    </NokninModal>
</div>

@code {
    private bool _modalOpen;

    private void OpenModal()
    {
        _modalOpen = true;
    }

    private void CloseModal()
    {
        _modalOpen = false;
    }
}