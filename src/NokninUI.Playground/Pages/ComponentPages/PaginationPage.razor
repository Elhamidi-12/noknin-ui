@page "/components/pagination"
@using NokninUI.Data.Enums

<PageTitle>Pagination - NokninUI</PageTitle>

<div class="demo-page">
    <div class="demo-header">
        <p class="demo-eyebrow">Component</p>
        <h1>Pagination</h1>
        <p>Use pagination to navigate through large result sets in smaller pages.</p>
    </div>

    <h2>Examples</h2>

    <div style="display:grid; gap:1.5rem; max-width:720px;">
        <NokninPagination TotalItems="128"
                          PageSize="10"
                          Page="@_paginationPage"
                          PageChanged="value => _paginationPage = value" />

        <NokninPagination TotalItems="80"
                          PageSize="10"
                          Size="NokninSize.Small"
                          Page="@_smallPaginationPage"
                          PageChanged="value => _smallPaginationPage = value" />

        <NokninPagination TotalItems="250"
                          PageSize="25"
                          Size="NokninSize.Large"
                          Page="@_largePaginationPage"
                          PageChanged="value => _largePaginationPage = value" />

        <NokninPagination TotalItems="50"
                          PageSize="10"
                          Page="1"
                          Disabled />

        <NokninPagination TotalItems="128"
                          PageSize="10"
                          ShowSummary="false"
                          Page="@_compactPaginationPage"
                          PageChanged="value => _compactPaginationPage = value" />

        <NokninPagination TotalItems="0"
                          PageSize="10"
                          Page="1"
                          AriaLabel="Empty results pagination" />
    </div>
</div>

@code {
    private int _paginationPage = 1;
    private int _smallPaginationPage = 2;
    private int _largePaginationPage = 5;
    private int _compactPaginationPage = 3;
}