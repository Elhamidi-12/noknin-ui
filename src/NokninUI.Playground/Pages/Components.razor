@page "/components"
@using NokninUI.Data.Enums
@inject NokninToastService Toasts


<PageTitle>Buttons</PageTitle>

<div class="demo-page">
    <div class="demo-header">
        <h1>Buttons</h1>
    </div>

    <div class="button-row">
        <NokninButton Variant="NokninVariant.Primary">Primary</NokninButton>
        <NokninButton Variant="NokninVariant.Secondary">Secondary</NokninButton>
        <NokninButton Variant="NokninVariant.Ghost">Ghost</NokninButton>
        <NokninButton Variant="NokninVariant.Destructive">Destructive</NokninButton>
    </div>

    <div class="button-row">
        <NokninButton Size="NokninSize.Small">Small</NokninButton>
        <NokninButton Size="NokninSize.Medium">Medium</NokninButton>
        <NokninButton Size="NokninSize.Large">Large</NokninButton>
        <NokninButton Disabled>Disabled</NokninButton>
    </div>
    <hr style="margin:2rem 0;" />

    <h2>Text Fields</h2>

    <div style="max-width: 400px; display:grid; gap:1rem;">

        <NokninTextField Label="Email" Placeholder="you@example.com" Description="Enter your work email." />

        <NokninTextField Label="Full name" Placeholder="John Doe" Required />

        <NokninTextField Label="Username" Placeholder="@noknin" ErrorText="Username is already taken." />

        <NokninTextField Label="Disabled field" Placeholder="Disabled" Disabled />

    </div>

    <hr style="margin:2rem 0;" />

    <h2>Text Area</h2>

    <div style="max-width:520px; display:grid; gap:1rem;">
        <NokninTextArea Label="Message" Placeholder="Write your message..."
                        Description="Use this for longer free-form text." @bind-Value="_message" />

        <NokninTextArea Label="Required message" Placeholder="This field is required" Required
                        @bind-Value="_requiredMessage" />

        <NokninTextArea Label="With character count" Placeholder="Maximum 120 characters" MaxLength="120"
                        ShowCharacterCount @bind-Value="_limitedMessage" />

        <NokninTextArea Label="Error message" Placeholder="Write something..." ErrorText="Message is required."
                        @bind-Value="_errorMessage" />

        <NokninTextArea Label="Disabled textarea" Placeholder="Disabled" Disabled />

        <NokninTextArea Label="Read only textarea" Value="This content is read-only." ReadOnly />

        <NokninTextArea Label="Small textarea" Placeholder="Small" Size="NokninSize.Small" Rows="3"
                        @bind-Value="_smallTextArea" />

        <NokninTextArea Label="Medium textarea" Placeholder="Medium" Size="NokninSize.Medium" Rows="3"
                        @bind-Value="_mediumTextArea" />

        <NokninTextArea Label="Large textarea" Placeholder="Large" Size="NokninSize.Large" Rows="3"
                        @bind-Value="_largeTextArea" />
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Cards</h2>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1rem;">
        <NokninCard>
            <Header>
                Card title
            </Header>

            <ChildContent>
                This is a basic elevated card using NokninUI semantic tokens.
            </ChildContent>

            <Footer>
                <NokninButton Variant="NokninVariant.Ghost">Cancel</NokninButton>
                <NokninButton Variant="NokninVariant.Primary">Save</NokninButton>
            </Footer>
        </NokninCard>

        <NokninCard Variant="NokninCardVariant.Outlined">
            <Header>
                Outlined card
            </Header>

            <ChildContent>
                Useful for dashboards, settings pages, and grouped content.
            </ChildContent>
        </NokninCard>

        <NokninCard Variant="NokninCardVariant.Ghost" Interactive>
            <Header>
                Interactive ghost card
            </Header>

            <ChildContent>
                Hover this card to test the interactive state.
            </ChildContent>
        </NokninCard>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Badges</h2>

    <div style="display:flex; gap:.75rem; flex-wrap:wrap; align-items:center;">
        <NokninBadge Variant="NokninBadgeVariant.Primary">Primary</NokninBadge>
        <NokninBadge Variant="NokninBadgeVariant.Secondary">Secondary</NokninBadge>
        <NokninBadge Variant="NokninBadgeVariant.Success">Success</NokninBadge>
        <NokninBadge Variant="NokninBadgeVariant.Warning">Warning</NokninBadge>
        <NokninBadge Variant="NokninBadgeVariant.Error">Error</NokninBadge>
        <NokninBadge Variant="NokninBadgeVariant.Info">Info</NokninBadge>
        <NokninBadge Variant="NokninBadgeVariant.Neutral">Neutral</NokninBadge>
    </div>

    <div style="display:flex; gap:.75rem; flex-wrap:wrap; align-items:center; margin-top:1rem;">
        <NokninBadge Size="NokninSize.Small">Small</NokninBadge>
        <NokninBadge Size="NokninSize.Medium">Medium</NokninBadge>
        <NokninBadge Size="NokninSize.Large">Large</NokninBadge>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Alerts</h2>

    <div style="display:grid; gap:1rem; max-width:720px;">
        <NokninAlert Title="Info alert" Variant="NokninAlertVariant.Info">
            This is a helpful informational message.
        </NokninAlert>

        <NokninAlert Title="Success alert" Variant="NokninAlertVariant.Success">
            Your changes were saved successfully.
        </NokninAlert>

        <NokninAlert Title="Warning alert" Variant="NokninAlertVariant.Warning">
            Please review this before continuing.
        </NokninAlert>

        <NokninAlert Title="Error alert" Variant="NokninAlertVariant.Error">
            Something went wrong. Please try again.
        </NokninAlert>

        <NokninAlert Title="Dismissible alert" Variant="NokninAlertVariant.Neutral" Dismissible
                     OnDismiss="HandleAlertDismiss">
            This alert has a close button.
        </NokninAlert>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Modal</h2>

    <NokninButton Variant="NokninVariant.Primary" OnClick="OpenModal">
        Open modal
    </NokninButton>

    <NokninModal Open="@_modalOpen" OpenChanged="@(value => _modalOpen = value)" Title="Delete project"
                 Size="NokninModalSize.Medium">

        <ChildContent>
            Are you sure you want to delete this project? This action cannot be undone.
        </ChildContent>

        <Footer>
            <NokninButton Variant="NokninVariant.Ghost" OnClick="CloseModal">
                Cancel
            </NokninButton>

            <NokninButton Variant="NokninVariant.Destructive" OnClick="CloseModal">
                Delete
            </NokninButton>
        </Footer>
    </NokninModal>

    <hr style="margin:2rem 0;" />

    <h2>Dropdown</h2>

    <NokninDropdown Align="NokninDropdownAlign.Start">
        <Trigger>
            Actions ▾
        </Trigger>

        <ChildContent>
            <NokninDropdownItem OnClick="HandleDropdownAction">
                Edit
            </NokninDropdownItem>

            <NokninDropdownItem>
                Duplicate
            </NokninDropdownItem>

            <NokninDropdownItem Disabled>
                Archive
            </NokninDropdownItem>

            <NokninDropdownItem>
                Delete
            </NokninDropdownItem>
        </ChildContent>
    </NokninDropdown>

    <hr style="margin:2rem 0;" />

    <h2>Tabs</h2>

    <NokninTabs Value="@_activeTab" ValueChanged="value => _activeTab = value">
        <Tabs>
            <NokninTab Value="overview">Overview</NokninTab>
            <NokninTab Value="usage">Usage</NokninTab>
            <NokninTab Value="settings">Settings</NokninTab>
            <NokninTab Value="disabled" Disabled>Disabled</NokninTab>
        </Tabs>

        <ChildContent>
            <NokninTabPanel Value="overview">
                Overview content for NokninUI tabs.
            </NokninTabPanel>

            <NokninTabPanel Value="usage">
                Usage examples and implementation notes.
            </NokninTabPanel>

            <NokninTabPanel Value="settings">
                Settings and configuration content.
            </NokninTabPanel>
        </ChildContent>
    </NokninTabs>

    <hr style="margin:2rem 0;" />

    <h2>Toasts</h2>

    <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
        <NokninButton Variant="NokninVariant.Primary" OnClick="ShowInfoToast">
            Show info toast
        </NokninButton>

        <NokninButton Variant="NokninVariant.Primary" OnClick="ShowSuccessToast">
            Show success toast
        </NokninButton>

        <NokninButton Variant="NokninVariant.Destructive" OnClick="ShowErrorToast">
            Show error toast
        </NokninButton>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Accordion</h2>

    <div style="max-width:720px;">
        <NokninAccordion>
            <NokninAccordionItem Value="tokens" Title="Semantic tokens">
                NokninUI uses semantic CSS variables for color, spacing, typography, radius, shadow, and motion.
            </NokninAccordionItem>

            <NokninAccordionItem Value="themes" Title="Dark and light themes">
                Theme switching works through data-theme attributes and token overrides.
            </NokninAccordionItem>

            <NokninAccordionItem Value="accessibility" Title="Accessibility">
                Components use native HTML, visible focus states, ARIA where needed, and keyboard-friendly behavior.
            </NokninAccordionItem>

            <NokninAccordionItem Value="disabled" Title="Disabled item" Disabled>
                This content cannot be opened.
            </NokninAccordionItem>
        </NokninAccordion>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Tooltip</h2>

    <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center;">
        <NokninTooltip Text="This tooltip appears above." Position="NokninTooltipPosition.Top">
            <NokninButton Variant="NokninVariant.Secondary">Top</NokninButton>
        </NokninTooltip>

        <NokninTooltip Text="This tooltip appears below." Position="NokninTooltipPosition.Bottom">
            <NokninButton Variant="NokninVariant.Secondary">Bottom</NokninButton>
        </NokninTooltip>

        <NokninTooltip Text="This tooltip appears left." Position="NokninTooltipPosition.Left">
            <NokninButton Variant="NokninVariant.Secondary">Left</NokninButton>
        </NokninTooltip>

        <NokninTooltip Text="This tooltip appears right." Position="NokninTooltipPosition.Right">
            <NokninButton Variant="NokninVariant.Secondary">Right</NokninButton>
        </NokninTooltip>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Select</h2>

    <div style="max-width:400px; display:grid; gap:1rem;">
        <NokninSelect Label="Framework" Placeholder="Choose framework" Options="@_frameworkOptions"
                      Value="@_selectedFramework" ValueChanged="value => _selectedFramework = value"
                      Description="Select the framework you use most." />

        <NokninSelect Label="Required status" Placeholder="Choose status" Options="@_statusOptions"
                      Value="@_selectedStatus" ValueChanged="value => _selectedStatus = value" ErrorText="Status is required."
                      Required />

        <NokninSelect Label="Disabled select" Placeholder="Unavailable" Options="@_frameworkOptions" Disabled />

        <NokninSelect Label="Small select" Placeholder="Choose framework" Size="NokninSize.Small"
                      Options="@_frameworkOptions" Value="@_smallFramework" ValueChanged="value => _smallFramework = value" />

        <NokninSelect Label="Medium select" Placeholder="Choose framework" Size="NokninSize.Medium"
                      Options="@_frameworkOptions" Value="@_mediumFramework" ValueChanged="value => _mediumFramework = value" />

        <NokninSelect Label="Large select" Placeholder="Choose framework" Size="NokninSize.Large"
                      Options="@_frameworkOptions" Value="@_largeFramework" ValueChanged="value => _largeFramework = value" />

        <NokninSelect Label="With disabled option" Placeholder="Try selecting Angular" Options="@_frameworkOptions"
                      Value="@_disabledOptionFramework" ValueChanged="value => _disabledOptionFramework = value"
                      Description="Angular is disabled and should not be selectable." />
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Checkbox</h2>

    <div style="max-width:420px; display:grid; gap:1rem;">
        <NokninCheckbox Label="Accept terms" Description="I agree to the terms and privacy policy."
                        @bind-Checked="_acceptedTerms" />

        <NokninCheckbox Label="Required checkbox" Description="This checkbox is required." Required
                        @bind-Checked="_requiredCheckbox" />

        <NokninCheckbox Label="Error checkbox" ErrorText="You must accept this before continuing."
                        @bind-Checked="_errorCheckbox" />

        <NokninCheckbox Label="Disabled checkbox" Description="This option is currently unavailable." Disabled />

        <NokninCheckbox Label="Checked disabled checkbox" Description="This option is locked on." Checked="true"
                        Disabled />

        <NokninCheckbox Label="Small checkbox" Size="NokninSize.Small" @bind-Checked="_smallCheckbox" />

        <NokninCheckbox Label="Medium checkbox" Size="NokninSize.Medium" @bind-Checked="_mediumCheckbox" />

        <NokninCheckbox Label="Large checkbox" Size="NokninSize.Large" @bind-Checked="_largeCheckbox" />
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Radio</h2>

    <div style="max-width:520px; display:grid; gap:1.5rem;">
        <NokninRadioGroup Label="Framework" Description="Choose the framework you use most."
                          Value="@_selectedRadioFramework" ValueChanged="value => _selectedRadioFramework = value">
            <NokninRadio Value="blazor" Label="Blazor" Description="A .NET web UI framework." />
            <NokninRadio Value="react" Label="React" Description="A JavaScript UI library." />
            <NokninRadio Value="vue" Label="Vue" Description="A progressive JavaScript framework." />
        </NokninRadioGroup>

        <NokninRadioGroup Label="Horizontal options" Orientation="NokninRadioOrientation.Horizontal"
                          Value="@_selectedRadioSize" ValueChanged="value => _selectedRadioSize = value">
            <NokninRadio Value="small" Label="Small" />
            <NokninRadio Value="medium" Label="Medium" />
            <NokninRadio Value="large" Label="Large" />
        </NokninRadioGroup>

        <NokninRadioGroup Label="Required status" Required ErrorText="Please select a status."
                          Value="@_selectedRadioStatus" ValueChanged="value => _selectedRadioStatus = value">
            <NokninRadio Value="active" Label="Active" />
            <NokninRadio Value="pending" Label="Pending" />
            <NokninRadio Value="archived" Label="Archived" />
        </NokninRadioGroup>

        <NokninRadioGroup Label="Disabled group" Disabled Value="@_disabledRadioValue"
                          ValueChanged="value => _disabledRadioValue = value">
            <NokninRadio Value="one" Label="One" />
            <NokninRadio Value="two" Label="Two" />
        </NokninRadioGroup>

        <NokninRadioGroup Label="Sizes" Value="@_selectedRadioExampleSize"
                          ValueChanged="value => _selectedRadioExampleSize = value">
            <NokninRadio Value="small" Label="Small radio" Size="NokninSize.Small" />
            <NokninRadio Value="medium" Label="Medium radio" Size="NokninSize.Medium" />
            <NokninRadio Value="large" Label="Large radio" Size="NokninSize.Large" />
        </NokninRadioGroup>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Switch</h2>

    <div style="max-width:420px; display:grid; gap:1rem;">
        <NokninSwitch Label="Enable notifications" Description="Receive updates about important activity."
                      @bind-Checked="_notificationsEnabled" />

        <NokninSwitch Label="Required switch" Description="This setting must be enabled before continuing." Required
                      @bind-Checked="_requiredSwitch" />

        <NokninSwitch Label="Error switch" ErrorText="You must enable this setting." @bind-Checked="_errorSwitch" />

        <NokninSwitch Label="Disabled switch" Description="This setting is unavailable." Disabled />

        <NokninSwitch Label="Checked disabled switch" Description="This setting is locked on." Checked="true"
                      Disabled />

        <NokninSwitch Label="Small switch" Size="NokninSize.Small" @bind-Checked="_smallSwitch" />

        <NokninSwitch Label="Medium switch" Size="NokninSize.Medium" @bind-Checked="_mediumSwitch" />

        <NokninSwitch Label="Large switch" Size="NokninSize.Large" @bind-Checked="_largeSwitch" />
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Table</h2>

    <div style="display:grid; gap:2rem;">
        <NokninTable Caption="Basic project table">
            <NokninTableHeader>
                <NokninTableRow>
                    <NokninTableCell Header>Project</NokninTableCell>
                    <NokninTableCell Header Align="NokninTableCellAlign.Center">Status</NokninTableCell>
                    <NokninTableCell Header Numeric>Progress</NokninTableCell>
                    <NokninTableCell Header>No Wrap</NokninTableCell>
                </NokninTableRow>
            </NokninTableHeader>

            <NokninTableBody>
                <NokninTableRow>
                    <NokninTableCell>NokninUI</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">
                        <NokninBadge Variant="NokninBadgeVariant.Success">Active</NokninBadge>
                    </NokninTableCell>
                    <NokninTableCell Numeric>80%</NokninTableCell>
                    <NokninTableCell NoWrap>Updated today</NokninTableCell>
                </NokninTableRow>

                <NokninTableRow Selected>
                    <NokninTableCell>Playground</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">
                        <NokninBadge Variant="NokninBadgeVariant.Info">Testing</NokninBadge>
                    </NokninTableCell>
                    <NokninTableCell Numeric>55%</NokninTableCell>
                    <NokninTableCell NoWrap>Updated yesterday</NokninTableCell>
                </NokninTableRow>

                <NokninTableRow Disabled>
                    <NokninTableCell>Docs</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">
                        <NokninBadge Variant="NokninBadgeVariant.Neutral">Paused</NokninBadge>
                    </NokninTableCell>
                    <NokninTableCell Numeric>20%</NokninTableCell>
                    <NokninTableCell NoWrap>Archived</NokninTableCell>
                </NokninTableRow>
            </NokninTableBody>
        </NokninTable>

        <NokninTable Variant="NokninTableVariant.Striped" Hoverable Caption="Striped hoverable table">
            <NokninTableHeader>
                <NokninTableRow>
                    <NokninTableCell Header>Name</NokninTableCell>
                    <NokninTableCell Header Align="NokninTableCellAlign.Center">Role</NokninTableCell>
                    <NokninTableCell Header Numeric>Issues</NokninTableCell>
                </NokninTableRow>
            </NokninTableHeader>

            <NokninTableBody>
                <NokninTableRow OnClick="HandleTableRowClick">
                    <NokninTableCell>Ada</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">Engineer</NokninTableCell>
                    <NokninTableCell Numeric>12</NokninTableCell>
                </NokninTableRow>

                <NokninTableRow OnClick="HandleTableRowClick">
                    <NokninTableCell>Linus</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">Designer</NokninTableCell>
                    <NokninTableCell Numeric>7</NokninTableCell>
                </NokninTableRow>

                <NokninTableRow OnClick="HandleTableRowClick">
                    <NokninTableCell>Grace</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">Product</NokninTableCell>
                    <NokninTableCell Numeric>4</NokninTableCell>
                </NokninTableRow>
            </NokninTableBody>
        </NokninTable>

        <NokninTable Variant="NokninTableVariant.Bordered" Size="NokninSize.Small" Compact
                     Caption="Bordered compact table">
            <NokninTableHeader>
                <NokninTableRow>
                    <NokninTableCell Header>Package</NokninTableCell>
                    <NokninTableCell Header Align="NokninTableCellAlign.Center">Version</NokninTableCell>
                    <NokninTableCell Header Align="NokninTableCellAlign.End">Status</NokninTableCell>
                </NokninTableRow>
            </NokninTableHeader>

            <NokninTableBody>
                <NokninTableRow>
                    <NokninTableCell>NokninUI</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">0.1.0</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.End">Local</NokninTableCell>
                </NokninTableRow>

                <NokninTableRow>
                    <NokninTableCell>NokninUI.Playground</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.Center">0.1.0</NokninTableCell>
                    <NokninTableCell Align="NokninTableCellAlign.End">Running</NokninTableCell>
                </NokninTableRow>
            </NokninTableBody>
        </NokninTable>
        
        <NokninTable Empty EmptyColSpan="3" Caption="Empty table state">
            <EmptyContent>
                <div style="display:grid; gap:.5rem; justify-items:center;">
                    <strong>No projects found</strong>
                    <span>Try changing your filters or create a new project.</span>
                </div>
            </EmptyContent>
        </NokninTable>
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Pagination</h2>

    <div style="display:grid; gap:1.5rem; max-width:720px;">
        <NokninPagination TotalItems="128" PageSize="10" Page="@_paginationPage"
                          PageChanged="value => _paginationPage = value" />

        <NokninPagination TotalItems="80" PageSize="10" Size="NokninSize.Small" Page="@_smallPaginationPage"
                          PageChanged="value => _smallPaginationPage = value" />

        <NokninPagination TotalItems="250" PageSize="25" Size="NokninSize.Large" Page="@_largePaginationPage"
                          PageChanged="value => _largePaginationPage = value" />

        <NokninPagination TotalItems="50" PageSize="10" Page="1" Disabled />

        <NokninPagination TotalItems="128" PageSize="10" ShowSummary="false" Page="@_compactPaginationPage"
                          PageChanged="value => _compactPaginationPage = value" />
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Paged Table</h2>

    <div style="display:grid; gap:1rem;">
        <NokninTable Variant="NokninTableVariant.Striped" Hoverable Caption="Paged table example">
            <NokninTableHeader>
                <NokninTableRow>
                    <NokninTableCell Header>Project</NokninTableCell>
                    <NokninTableCell Header Align="NokninTableCellAlign.Center">Status</NokninTableCell>
                    <NokninTableCell Header Numeric>Progress</NokninTableCell>
                    <NokninTableCell Header NoWrap>Updated</NokninTableCell>
                </NokninTableRow>
            </NokninTableHeader>

            <NokninTableBody>
                @foreach (var project in PagedProjects)
                {
                    <NokninTableRow>
                        <NokninTableCell>@project.Name</NokninTableCell>

                        <NokninTableCell Align="NokninTableCellAlign.Center">
                            <NokninBadge Variant="@GetProjectBadgeVariant(project.Status)">
                                @project.Status
                            </NokninBadge>
                        </NokninTableCell>

                        <NokninTableCell Numeric>
                            @project.Progress%
                        </NokninTableCell>

                        <NokninTableCell NoWrap>
                            @project.Updated
                        </NokninTableCell>
                    </NokninTableRow>
                }
            </NokninTableBody>
        </NokninTable>

        <NokninPagination TotalItems="@_projects.Count" PageSize="@_pagedTablePageSize" Page="@_pagedTablePage"
                          PageChanged="HandlePagedTablePageChanged" />
    </div>

    <hr style="margin:2rem 0;" />

    <h2>Data Grid</h2>

    <div style="display:grid; gap:2rem;">
        <NokninDataGrid TItem="ProjectRow" Items="@_projects" Caption="Data grid with template columns" Striped
                        Hoverable>
            <Columns>
                <NokninDataGridColumn TItem="ProjectRow" Header="Project" Field="Name" />

                <NokninDataGridColumn TItem="ProjectRow" Header="Status" Align="NokninTableCellAlign.Center">
                    <Template Context="project">
                        <NokninBadge Variant="@GetProjectBadgeVariant(project.Status)">
                            @project.Status
                        </NokninBadge>
                    </Template>
                </NokninDataGridColumn>

                <NokninDataGridColumn TItem="ProjectRow" Header="Progress" Field="Progress" Numeric />

                <NokninDataGridColumn TItem="ProjectRow" Header="Updated" Field="Updated" NoWrap />
            </Columns>
        </NokninDataGrid>

        <NokninDataGrid TItem="ProjectRow" Items="@_emptyProjects" EmptyText="No projects found."
