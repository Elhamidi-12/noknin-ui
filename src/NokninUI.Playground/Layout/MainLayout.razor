@inherits LayoutComponentBase

<div class="@ShellClass" data-theme="@Theme">
    <aside class="@SidebarClass" id="docs-navigation">
        <NavMenu Collapsed="_navCollapsed" OnNavigate="CloseMobileNav" />
    </aside>

    @if (_mobileNavOpen)
    {
        <button class="noknin-docs-backdrop"
                type="button"
                aria-label="Close navigation"
                @onclick="CloseMobileNav">
        </button>
    }

    <div class="noknin-docs-main">
        <header class="noknin-docs-header">
            <div class="noknin-docs-header__start">
                <button class="noknin-docs-icon-button noknin-docs-mobile-menu"
                        type="button"
                        aria-label="Open navigation"
                        aria-controls="docs-navigation"
                        aria-expanded="@_mobileNavOpen"
                        @onclick="ToggleMobileNav">
                    <NokninIcon Name="NokninIconName.Menu" />
                </button>

                <button class="noknin-docs-icon-button noknin-docs-collapse-button"
                        type="button"
                        aria-label="@CollapseLabel"
                        aria-controls="docs-navigation"
                        aria-expanded="@(!_navCollapsed)"
                        @onclick="ToggleNav">
                    <NokninIcon Name="@CollapseIconName" />
                </button>

                <div>
                    <p class="noknin-docs-eyebrow">NokninUI Playground</p>
                    <h1 class="noknin-docs-title">Semantic Blazor components</h1>
                </div>
            </div>

            <div class="noknin-docs-actions">
                <button class="noknin-docs-theme-toggle"
                        type="button"
                        aria-label="@ThemeLabel"
                        title="@ThemeLabel"
                        @onclick="ToggleTheme">
                    <NokninIcon Name="@ThemeIconName" />
                </button>

                <a class="noknin-docs-link"
                   href="https://github.com/Elhamidi-12/noknin-ui"
                   target="_blank"
                   rel="noopener noreferrer">
                    <DocsIcon Name="github" Size="16" Class="noknin-docs-link-icon" />
                    GitHub
                </a>
            </div>
        </header>

        <main class="noknin-docs-content">
            @Body
        </main>
    </div>

    <NokninToastContainer Position="NokninToastPosition.TopRight" />
</div>

@code {
    private bool _dark;
    private bool _navCollapsed;
    private bool _mobileNavOpen;

    private string Theme => _dark ? "dark" : "light";

    private string ThemeLabel => _dark ? "Switch to light theme" : "Switch to dark theme";

    private NokninIconName ThemeIconName => _dark ? NokninIconName.Sun : NokninIconName.Moon;

    private string CollapseLabel => _navCollapsed ? "Expand navigation" : "Collapse navigation";

    private NokninIconName CollapseIconName => _navCollapsed ? NokninIconName.ChevronRight : NokninIconName.ChevronLeft;

    private string ShellClass => _mobileNavOpen
        ? "noknin-docs-shell noknin-docs-shell--nav-open"
        : "noknin-docs-shell";

    private string SidebarClass => _navCollapsed
        ? "noknin-docs-sidebar noknin-docs-sidebar--collapsed"
        : "noknin-docs-sidebar";

    private void ToggleTheme()
    {
        _dark = !_dark;
    }

    private void ToggleNav()
    {
        _navCollapsed = !_navCollapsed;
    }

    private void ToggleMobileNav()
    {
        _mobileNavOpen = !_mobileNavOpen;
    }

    private void CloseMobileNav()
    {
        _mobileNavOpen = false;
    }
}
