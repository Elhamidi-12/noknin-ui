@inherits LayoutComponentBase

<div class="noknin-docs-shell" data-theme="@Theme">
    <aside class="noknin-docs-sidebar">
        <NavMenu />
    </aside>

    <div class="noknin-docs-main">
        <header class="noknin-docs-header">
            <div>
                <p class="noknin-docs-eyebrow">NokninUI Playground</p>
                <h1 class="noknin-docs-title">Semantic Blazor components</h1>
            </div>

            <div class="noknin-docs-actions">
                <button class="noknin-docs-theme-toggle" type="button" @onclick="ToggleTheme">
                    @ThemeLabel
                </button>

                <a class="noknin-docs-link"
                   href="https://github.com/Elhamidi-12/noknin-ui"
                   target="_blank"
                   rel="noopener noreferrer">
                    GitHub
                </a>
            </div>
        </header>

        <main class="noknin-docs-content">
            @Body
        </main>
    </div>

    <NokninToastContainer Position="NokninToastPosition.TopRight" />
</div>

@code {
    private bool _dark;

    private string Theme => _dark ? "dark" : "light";

    private string ThemeLabel => _dark ? "Light theme" : "Dark theme";

    private void ToggleTheme()
    {
        _dark = !_dark;
    }
}