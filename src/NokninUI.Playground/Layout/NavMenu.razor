@code {
    [Parameter]
    public bool Collapsed { get; set; }

    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private string NavClass => Collapsed
        ? "noknin-docs-nav noknin-docs-nav--collapsed"
        : "noknin-docs-nav";

    private Task HandleNavigate()
    {
        return OnNavigate.InvokeAsync();
    }
